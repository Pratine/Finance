generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Models ───────────────────────────────────────────────────────────────────
// SQLite has no native enum type so all enum-like fields are stored as String.
// Valid values are enforced at the application layer.
// TransactionType: CREDIT | DEBIT
// CategoryType:    INCOME | EXPENSE
// InterestType:    PERCENTAGE | FIXED
// Frequency:       WEEKLY | MONTHLY | QUARTERLY | YEARLY
// DebtType:        LOAN | RECEIVABLE
// DebtStatus:      ACTIVE | PAID | WRITTEN_OFF
// LotType:         BUY | SELL

model Broker {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  color       String?
  icon        String?
  investments Investment[]
}

model InvestmentType {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  color       String?
  icon        String?
  investments Investment[]
}

model Bank {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  color    String?
  icon     String?
  accounts Account[]
}

model BalanceCorrection {
  id         Int      @id @default(autoincrement())
  accountId  Int
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  oldBalance Decimal
  newBalance Decimal
  note       String?
  createdAt  DateTime @default(now())
}

model AccountType {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  color    String?
  icon     String?
  accounts Account[]
}

model Account {
  id            Int     @id @default(autoincrement())
  name          String
  bankId        Int
  bank          Bank    @relation(fields: [bankId], references: [id])
  accountNumber String?
  typeId        Int
  type          AccountType @relation(fields: [typeId], references: [id])
  balance       Decimal @default(0)
  currency      String  @default("EUR")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions       Transaction[]
  savingsGoals       SavingsGoal[]
  recurringBills     RecurringBill[]
  recurringIncome    RecurringIncome[]
  balanceCorrections BalanceCorrection[]
  debts              Debt[]
  importHistory      ImportHistory[]
}

model ImportHistory {
  id         Int      @id @default(autoincrement())
  filename   String
  format     String
  accountId  Int?
  account    Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  imported   Int
  skipped    Int
  errors     Int      @default(0)
  importedAt DateTime @default(now())
}

model CategoryRule {
  id         Int      @id @default(autoincrement())
  pattern    String
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  type      String   // INCOME | EXPENSE
  color     String?
  icon      String?
  createdAt DateTime @default(now())

  transactions    Transaction[]
  splits          TransactionSplit[]
  budgets         Budget[]
  recurringBills  RecurringBill[]
  recurringIncome RecurringIncome[]
  rules           CategoryRule[]
}

model Transaction {
  id              Int      @id @default(autoincrement())
  accountId       Int
  account         Account  @relation(fields: [accountId], references: [id])
  categoryId      Int?
  category        Category? @relation(fields: [categoryId], references: [id])
  recurringBillId Int?
  recurringBill   RecurringBill? @relation(fields: [recurringBillId], references: [id], onDelete: SetNull)
  date            DateTime
  valueDate       DateTime?
  description     String
  amount          Decimal
  type            String   // CREDIT | DEBIT
  runningBalance  Decimal?
  notes           String?
  importHash      String?  @unique
  createdAt       DateTime @default(now())

  tags   TransactionTag[]
  splits TransactionSplit[]
}

model TransactionSplit {
  id            Int       @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    Int?
  category      Category? @relation(fields: [categoryId], references: [id])
  amount        Decimal
  notes         String?
}

model Tag {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  color        String?
  transactions TransactionTag[]
}

model TransactionTag {
  transactionId Int
  tagId         Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model Budget {
  id         Int      @id @default(autoincrement())
  categoryId Int      @unique
  category   Category @relation(fields: [categoryId], references: [id])
  amount     Decimal
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SavingsGoal {
  id                        Int      @id @default(autoincrement())
  accountId                 Int?     @unique
  account                   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name                      String
  targetAmount              Decimal
  currentAmount             Decimal  @default(0)
  deadline                  DateTime?
  interestType              String?  // PERCENTAGE | FIXED
  interestValue             Decimal?
  interestFrequencyDays     Int?
  lastInterestApplied       DateTime?
  totalInterestEarned       Decimal  @default(0)
  contributionAmount        Decimal?
  contributionFrequencyDays Int?
  notes                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  snapshots SavingsSnapshot[]
}

model SavingsSnapshot {
  id     Int         @id @default(autoincrement())
  goalId Int
  goal   SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  date   DateTime    @default(now())
  amount Decimal
  note   String?
}

model RecurringBill {
  id          Int      @id @default(autoincrement())
  name        String
  amount      Decimal
  frequency   String   // WEEKLY | MONTHLY | QUARTERLY | YEARLY
  nextDueDate DateTime
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  accountId   Int?
  account     Account?  @relation(fields: [accountId], references: [id])
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
}

model ExchangeRate {
  id           Int      @id @default(autoincrement())
  fromCurrency String   @unique
  rate         Decimal
  updatedAt    DateTime @updatedAt
}

model PriceHistory {
  id           Int        @id @default(autoincrement())
  investmentId Int
  investment   Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  price        Decimal
  value        Decimal
  recordedAt   DateTime   @default(now())

  @@unique([investmentId, recordedAt])
}

model Debt {
  id              Int      @id @default(autoincrement())
  name            String
  type            String   // LOAN | RECEIVABLE
  counterparty    String
  principal       Decimal
  outstanding     Decimal
  interestRate    Decimal?
  frequency       String?  // WEEKLY | MONTHLY | QUARTERLY | YEARLY
  nextPaymentDate DateTime?
  startDate       DateTime
  endDate         DateTime?
  status          String   @default("ACTIVE") // ACTIVE | PAID | WRITTEN_OFF
  accountId       Int?
  account         Account? @relation(fields: [accountId], references: [id])
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments DebtPayment[]
}

model DebtPayment {
  id        Int      @id @default(autoincrement())
  debtId    Int
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  date      DateTime
  amount    Decimal
  principal Decimal
  interest  Decimal
  notes     String?
  createdAt DateTime @default(now())
}

model RecurringIncome {
  id               Int      @id @default(autoincrement())
  name             String
  amount           Decimal
  frequency        String   // WEEKLY | MONTHLY | QUARTERLY | YEARLY
  nextExpectedDate DateTime
  categoryId       Int?
  category         Category? @relation(fields: [categoryId], references: [id])
  accountId        Int?
  account          Account?  @relation(fields: [accountId], references: [id])
  notes            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Investment {
  id               Int            @id @default(autoincrement())
  name             String
  typeId           Int
  type             InvestmentType @relation(fields: [typeId], references: [id])
  amountIn         Decimal
  currentValue     Decimal
  currency         String  @default("EUR")
  isin             String?
  ticker           String?
  shares           Decimal?
  lastPriceFetched Decimal?
  priceUpdatedAt   DateTime?
  brokerId         Int?
  broker           Broker?  @relation(fields: [brokerId], references: [id])
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  priceHistory PriceHistory[]
  lots         InvestmentLot[]
}

model InvestmentLot {
  id            Int        @id @default(autoincrement())
  investmentId  Int
  investment    Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  type          String     @default("BUY") // BUY | SELL
  date          DateTime
  shares        Decimal
  pricePerShare Decimal
  totalCost     Decimal
  realizedGain  Decimal?
  notes         String?
  createdAt     DateTime   @default(now())
}
