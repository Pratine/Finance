{
  "name": "finance-app",
  "version": "0.2.0",
  "description": "Finance desktop app",
  "author": "Pratine",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on dist-electron/main/index.js && wait-on http://localhost:5173 && electron .\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "vitest run && vite build && tsc -p tsconfig.electron.json && electron-builder",
    "dist": "vitest run && prisma generate && vite build && tsc -p tsconfig.electron.json && electron-builder",
    "dist:demo": "node scripts/build-demo.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@tanstack/react-virtual": "^3.13.24",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.14.0",
    "prisma": "^5.14.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.finance.app",
    "productName": "Finance",
    "asar": true,
    "asarUnpack": [
      "node_modules/.prisma/**",
      "node_modules/@prisma/engines/**",
      "node_modules/prisma/query_engine-windows.dll.node"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "prisma/migrations/**/*",
      "prisma/schema.prisma",
      "prisma/**/*",
      "package.json"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "portable": {
      "artifactName": "Finance-Demo-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Finance",
      "include": "installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": "AppImage",
      "category": "Finance"
    },
    "publish": {
      "provider": "github",
      "owner": "Pratine",
      "repo": "Finance",
      "releaseType": "release"
    }
  }
}
